{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Serve PHP site on 8080",
            "type": "shell",
            "command": "C:\\xampp\\php\\php.exe",
            "args": [
                "-S",
                "0.0.0.0:8080",
                "-t",
                "${workspaceFolder}" 
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Server started",
                    "endsPattern": "Development Server (http://0.0.0.0:8080) started"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}